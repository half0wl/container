{
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "publish": "pnpm -C packages/container publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7"
  }
}
